{
  "schema_version": 1,
  "aegis_version": "{{VERSION}}",
  "installed_at": "{{INSTALLED_AT}}",
  "project_name": "{{PROJECT_NAME}}",
  "prefix_format": "sequencial",
  "language": "pt-BR",
  "watch": {
    "archive_after": 3,
    "block_on_red": false
  },
  "paths": {
    "sdd_dir": "aegis/specs/sdd",
    "forward_dir": "aegis/forward",
    "config_dir": "aegis/config"
  },
  "principles": {
    "enabled": true,
    "auto_load_into_plan": true
  },
  "telemetry": {
    "enabled": false
  }
}
